#!/bin/bash
# Spectri pre-commit hook — TEMPLATE ONLY.
#
# This file is NOT deployed directly. The install_git_hooks() function in
# git_hooks.py generates the actual hook with sys.executable baked in,
# guaranteeing the correct Python path regardless of the shell environment.
#
# This template exists only as documentation of what checks are enforced.
# See src/spectri_cli/hooks/pre_commit.py for the implementation.
#
# Checks enforced:
#   1. Multi-spec commit detection
#   2. Implementation summary immutability
#   3. AGENTS.md enforcement (placeholder)
#   4. Canonical source protection
#   5. Implementation summary enforcement
#   6. Timestamp pattern validation
#   7. Skill reference validation
#   8. Work cycle reminders (never blocks)
#   9. Meta.json validation (warn-only)
#
# Bypass all checks: git commit --no-verify
#
# Individual bypasses via env vars:
#   SKIP_MULTI_SPEC_CHECK=1  SKIP_SUMMARY_CHECK=1
#   SKIP_DEPLOY_CHECK=1      SKIP_TIMESTAMP_CHECK=1

echo "ERROR: This template should not be deployed directly." >&2
echo "Re-run 'spectri update' to generate the hook with the correct Python path." >&2
exit 1
